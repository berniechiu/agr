{
  "name": "agr-cli",
  "version": "0.4.0",
  "description": "Claude Code session browser CLI — browse, search, tag, and resume sessions beyond the built-in 10-session limit",
  "type": "module",
  "bin": {
    "agr": "./bin/agr.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "session",
    "resume",
    "tui",
    "ink"
  ],
  "license": "MIT",
  "author": "Bernie Chiu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/berniechiu/agr.git"
  },
  "bugs": {
    "url": "https://github.com/berniechiu/agr/issues"
  },
  "homepage": "https://github.com/berniechiu/agr#readme",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^7.0.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "memfs": "^4.17.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
